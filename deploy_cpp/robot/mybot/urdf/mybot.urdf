      <inertia ixx="0.0030336" ixy="0" ixz="0" iyy="0.0026249" iyz="0" izz="0.00046586"/>
    </inertial>
  </link>

  <joint name="FR_thigh_joint" type="revolute">
    <origin xyz="0.085 -0.03295 0" rpy="0 0 0"/>
    <parent link="FR_hip"/>
    <child link="FR_thigh"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.44" upper="1.44" effort="33.5" velocity="30.0"/>
  </joint>

  <link name="FR_calf">
    <visual>
      <geometry>
        <mesh filename="package://deploy_cpp/robot/mybot/meshes/FR_calf.STL"/>
