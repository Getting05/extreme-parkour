<?xml version="1.0" encoding="utf-8"?>
<!--
  Mybot Quadruped URDF
  Converted from mybot.xml (MuJoCo format).
  Joint names and link hierarchy match robot_config.h DOF order.
-->
<robot name="mybot">

  <!-- ==================== Materials ==================== -->
  <material name="body_color">
    <color rgba="0.67 0.69 0.77 1"/>
  </material>
  <material name="hip_color">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="thigh_color">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="calf_color">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="foot_color">
    <color rgba="0 0 0 1"/>
  </material>

  <!-- ==================== Base Link ==================== -->
  <!-- base_link is the fixed world reference frame -->
  <link name="base_link"/>

  <!-- body link (floating base of the robot) -->
  <link name="body">
    <visual>
      <geometry>
        <mesh filename="package://deploy_cpp/robot/mybot/meshes/body.STL"/>
      </geometry>
      <material name="body_color"/>
    </visual>
    <inertial>
      <origin xyz="-0.075044 0.0013153 0.023062" rpy="0 0 0"/>
      <mass value="5.3036"/>
      <inertia ixx="0.017259" ixy="0" ixz="0" iyy="0.017164" iyz="0" izz="0.012634"/>
    </inertial>
  </link>

  <!-- Floating joint: base_link -> body -->
  <!-- Initial position from MuJoCo: z=0.445m (standing height) -->
  <joint name="floating_base" type="fixed">
    <origin xyz="0 0 0.445" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="body"/>
  </joint>

  <!-- ==================== FR (Front Right) Leg ==================== -->

  <link name="FR_hip">
    <visual>
      <geometry>
        <mesh filename="package://deploy_cpp/robot/mybot/meshes/FR_hip.STL"/>
      </geometry>
      <material name="hip_color"/>
    </visual>
    <inertial>
      <origin xyz="0.050324 -0.0023835 -0.00001926" rpy="0 0 0"/>
      <mass value="0.64533"/>
      <inertia ixx="0.00081299" ixy="0" ixz="0" iyy="0.00051628" iyz="0" izz="0.00043556"/>
    </inertial>
  </link>

  <joint name="FR_hip_joint" type="revolute">
    <origin xyz="0.0946 -0.062 -0.071" rpy="0 0 0"/>
    <parent link="body"/>
    <child link="FR_hip"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.48" upper="0.48" effort="33.5" velocity="30.0"/>
  </joint>

  <link name="FR_thigh">
    <visual>
      <geometry>
        <mesh filename="package://deploy_cpp/robot/mybot/meshes/FR_thigh.STL"/>
      </geometry>
      <material name="thigh_color"/>
    </visual>
    <inertial>
      <origin xyz="0.0003687 -0.05094 -0.044849" rpy="0 0 0"/>
